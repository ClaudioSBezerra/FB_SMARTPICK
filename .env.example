# ── Banco de Dados ──────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=TROQUE_SENHA_FORTE
DB_NAME=fb_smartpick

# ── Segurança ────────────────────────────────────────────────────────────────
JWT_SECRET=TROQUE_SECRET_64_CHARS_ALEATORIO
COOKIE_SECURE=true

# ── Aplicação ────────────────────────────────────────────────────────────────
PORT=8082
APP_URL=https://smartpick.fbtax.cloud
ALLOWED_ORIGINS=https://smartpick.fbtax.cloud
APP_MODULE=smartpick

# ── SMTP (opcional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
